standings_cache.json

# Cache files
*.jsonl
esi_supplement.jsonl

# Downloaded archives (500MB+)
history-archive/

# Python bytecode
__pycache__/
*.py[cod]
*$py.class
*.pyo

# PyInstaller build output
build/
dist/
*.manifest

# Keep the spec file, ignore build artifacts
# EVE-Market-Scout.spec  <-- this IS tracked

# Virtual environments
venv/
env/
.venv/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log

# Test files
test_*.py
tests/

# Local-only modules (private, never committed)
drug_*

